{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/wp-content/themes/:path*",
      "destination": "https://wp.aykutaskeri.de/wp-content/themes/:path*"
    },
    {
      "source": "/wp-content/uploads/:path*",
      "destination": "https://wp.aykutaskeri.de/wp-content/uploads/:path*"
    }
  ]
}
