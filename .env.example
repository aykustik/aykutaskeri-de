# WordPress API Configuration

# Your WordPress site URL (without trailing slash)
NEXT_PUBLIC_WP_API_URL=https://aykutaskeri.de/wp-json

# Application Password (base64 encoded credentials)
# Format: base64("username:application_password")
# You can generate this yourself or leave empty for public endpoints
WP_AUTH_HEADER=

# For authenticated requests (protected content)
# Generate at: WordPress Admin → Users → Your Profile → Application Passwords
# Then encode with: echo -n "username:AppPassword" | base64

# WordPress SSH Access (for WP-CLI / ACF management)
# Required for: ACF field exports/imports, database operations
WP_SSH_HOST=w01b65d3.kasserver.com
WP_SSH_USER=ssh-w01b65d3
WP_SSH_KEY=/Users/USERNAME/.ssh/wp_cli_aykutaskeri
WP_PATH=/www/htdocs/w01b65d3/aykutaskeri.de
