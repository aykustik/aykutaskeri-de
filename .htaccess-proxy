# .htaccess für All-Inkl mit Vercel Proxy
# Füge dies am Ende deiner bestehenden .htaccess ein

# ========================================
# CV Proxy zu Vercel
# ========================================

# Nur aktivieren wenn mod_proxy verfügbar ist
<IfModule mod_proxy.c>
    RewriteEngine On
    RewriteBase /

    # Alle /cv/* Anfragen zu Vercel proxy-n
    # Ersetze 'deine-vercel-app.vercel.app' mit deiner tatsächlichen Vercel URL
    RewriteRule ^cv/(.*)$ https://deine-vercel-app.vercel.app/cv/$1 [P,L]
    
    # Auch die Index-Seite proxy-n (optional)
    # RewriteRule ^cv/?$ https://deine-vercel-app.vercel.app/cv [P,L]
</IfModule>

# ========================================
# Alternative: WordPress bleibt Hauptseite
# Falls du nur die CV-Routen umleiten willst:
# ========================================

# 1. Redirect zu Subdomain (einfacher)
# RewriteEngine On
# RewriteRule ^cv/(.*)$ https://cv.aykutaskeri.de/$1 [R=301,L]

# ========================================
# HINWEIS:
# ========================================
# Das Proxy-Setup erfordert:
# 1. mod_proxy muss aktiviert sein
# 2. SSL-Zertifikat auf beiden Domains
# 
# Einfacher ist die Nutzung einer Subdomain:
# - Erstelle cv.aykutaskeri.de bei All-Inkl
# - Konfiguriere bei Vercel als Custom Domain
# - Das ist zuverlässiger und einfacher
